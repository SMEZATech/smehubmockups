<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>LinkedIn Newsletter Performance — Comparative Review</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Hanken+Grotesk:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#16151D; --ink2:#43424F; --muted:#8C8B99; --faint:#B9B8C4;
    --line:#E9E8EF; --line2:#F1F0F6;
    --paper:#FFFFFF; --wash:#F7F6FC;
    --violet:#6744FF; --violet-deep:#4B2DD6; --violet-soft:#EEEAFF; --violet-soft2:#F5F2FF;
    --graphite:#33323F; --graphite-soft:#E7E6EC;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:#E9E9ED;
    color:var(--ink);
    font-family:'Hanken Grotesk',-apple-system,sans-serif;
    font-size:14.5px; line-height:1.5;
    -webkit-font-smoothing:antialiased;
    font-feature-settings:"tnum" 1,"lnum" 1;
  }
  .sheet{
    background:var(--paper);
    max-width:820px; margin:34px auto; padding:46px 50px 40px;
    border-radius:6px;
    box-shadow:0 1px 2px rgba(20,20,40,.06),0 24px 60px -20px rgba(20,20,40,.22);
    position:relative; overflow:hidden;
  }
  .sheet::before{
    content:""; position:absolute; top:0; left:0; right:0; height:5px;
    background:linear-gradient(90deg,var(--violet) 0%,var(--violet) 62%,var(--graphite) 62%,var(--graphite) 100%);
  }

  /* ---------- MASTHEAD ---------- */
  .masthead{display:flex; justify-content:space-between; align-items:flex-start; gap:24px;}
  .logo{height:30px; width:auto; display:block;}
  .meta{text-align:right; font-size:11px; color:var(--muted); line-height:1.7; letter-spacing:.01em;}
  .meta b{color:var(--ink2); font-weight:600;}
  .pill{
    display:inline-block; font-size:9.5px; font-weight:700; letter-spacing:.16em;
    text-transform:uppercase; color:var(--violet-deep);
    border:1.3px solid var(--violet); border-radius:999px; padding:3px 10px; margin-bottom:6px;
  }
  .title-block{margin-top:30px; padding-bottom:22px; border-bottom:1px solid var(--line);}
  .eyebrow{font-size:9.5px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:var(--violet); margin-bottom:9px;}
  h1.report-title{
    font-family:'Fraunces',Georgia,serif; font-weight:500; font-size:33px;
    line-height:1.08; letter-spacing:-.01em; margin:0; color:var(--ink);
  }
  .subtitle{margin-top:9px; font-size:13.5px; color:var(--ink2); font-weight:400;}
  .subtitle .vs{color:var(--violet-deep); font-weight:600;}
  a{color:inherit; text-decoration:none;}
  a.vs{transition:opacity .15s; border-bottom:1px solid rgba(75,45,214,.28); padding-bottom:1px;}
  a.vs:hover{opacity:.7;}
  .card-name a:hover{opacity:.7;}
  .card-link{
    display:inline-flex; align-items:center; gap:5px; margin-top:11px;
    font-size:10px; font-weight:700; letter-spacing:.01em; color:var(--violet-deep);
  }
  .card-link .arr{font-size:11px; line-height:1;}
  .card-link:hover{opacity:.7;}

  /* ---------- SECTION ---------- */
  section{margin-top:30px;}
  .sec-head{display:flex; align-items:baseline; gap:11px; margin-bottom:15px; break-after:avoid;}
  .charts,.norm,.cards,.demo-grid{break-inside:avoid;}
  .sec-num{
    font-family:'Fraunces',serif; font-size:13px; font-weight:500; color:var(--violet);
    border:1px solid var(--violet-soft); background:var(--violet-soft2); border-radius:6px;
    width:24px; height:24px; display:inline-flex; align-items:center; justify-content:center; flex:0 0 auto;
  }
  h2{font-size:16px; font-weight:800; letter-spacing:-.01em; margin:0; color:var(--ink);}

  /* ---------- IDENTITY CARDS ---------- */
  .cards{display:grid; grid-template-columns:1fr 1fr; gap:14px;}
  .card{
    border:1px solid var(--line); border-radius:13px; padding:18px 18px 16px;
    background:var(--paper); position:relative; break-inside:avoid;
  }
  .card.dfa{box-shadow:inset 4px 0 0 var(--graphite);}
  .card.sad{box-shadow:inset 4px 0 0 var(--violet);}
  .card-name{font-size:14px; font-weight:700; color:var(--ink); margin-bottom:2px; display:flex; align-items:center; gap:8px;}
  .dot{width:9px; height:9px; border-radius:3px; flex:0 0 auto;}
  .dot.dfa{background:var(--graphite);} .dot.sad{background:var(--violet);}
  .card-sub{font-size:10.5px; color:var(--muted); letter-spacing:.02em;}
  .card-big{font-family:'Hanken Grotesk'; font-size:38px; font-weight:700; line-height:1; margin:12px 0 2px; letter-spacing:-.02em;}
  .card.dfa .card-big{color:var(--graphite);} .card.sad .card-big{color:var(--violet-deep);}
  .card-biglabel{font-size:10px; color:var(--muted); text-transform:uppercase; letter-spacing:.12em; font-weight:600;}
  .card-period{margin-top:13px; padding-top:11px; border-top:1px dashed var(--line); font-size:11px; color:var(--ink2);}
  .card-period b{color:var(--ink); font-weight:600;}
  .card-period .win{color:var(--muted);}

  /* ---------- LEGEND ---------- */
  .legend{display:flex; gap:18px; align-items:center; margin:2px 0 16px; font-size:11px; color:var(--ink2);}
  .legend .lg{display:flex; align-items:center; gap:7px;}
  .legend .chip{width:13px; height:13px; border-radius:4px;}
  .legend .chip.dfa{background:var(--graphite);} .legend .chip.sad{background:var(--violet);}

  /* ---------- TABLE ---------- */
  table{width:100%; border-collapse:collapse; font-size:12.5px;}
  thead th{
    text-align:left; font-size:9.5px; font-weight:700; text-transform:uppercase; letter-spacing:.13em;
    color:var(--muted); padding:0 0 9px; border-bottom:1.5px solid var(--ink);
  }
  thead th.col-n{text-align:right;}
  thead th .ch{display:inline-flex; align-items:center; gap:6px; justify-content:flex-end;}
  thead th .chip{width:9px; height:9px; border-radius:3px;}
  .chip.dfa{background:var(--graphite);} .chip.sad{background:var(--violet);}
  tbody tr{border-bottom:1px solid var(--line2);}
  tbody tr:last-child{border-bottom:none;}
  td{padding:11px 0; vertical-align:top;}
  .t-metric{font-weight:600; color:var(--ink); width:48%;}
  .t-note{font-weight:400; font-size:10px; color:var(--muted); margin-top:2px;}
  .t-num{text-align:right; font-variant-numeric:tabular-nums; font-weight:600; font-size:14px;}
  .dfa-col{color:var(--graphite);} .sad-col{color:var(--violet-deep);}

  /* ---------- METRIC CHARTS ---------- */
  .charts{display:grid; grid-template-columns:1fr 1fr; gap:16px 26px;}
  .mc{break-inside:avoid;}
  .mc-label{font-size:11px; font-weight:700; color:var(--ink); margin-bottom:9px; letter-spacing:.01em;}
  .mc-rows{display:flex; flex-direction:column; gap:7px;}
  .mc-row{display:flex; align-items:center; gap:9px;}
  .mc-tag{font-size:9px; font-weight:700; color:var(--muted); width:26px; letter-spacing:.06em;}
  .mc-track{flex:1; height:14px; background:var(--line2); border-radius:5px; overflow:hidden;}
  .mc-fill{height:100%; border-radius:5px;}
  .mc-fill.dfa{background:var(--graphite);}
  .mc-fill.sad{background:linear-gradient(90deg,var(--violet),#7C5BFF);}
  .mc-val{font-size:11.5px; font-weight:700; font-variant-numeric:tabular-nums; min-width:42px; text-align:right; color:var(--ink);}

  /* ---------- NORMALISED ---------- */
  .norm{display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-top:4px;}
  .norm-card{border:1px solid var(--line); background:var(--wash); border-radius:13px; padding:16px 18px; break-inside:avoid;}
  .norm-label{font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.11em; color:var(--violet-deep); margin-bottom:10px;}
  .norm-vals{display:flex; gap:26px;}
  .norm-item{flex:1;}
  .norm-item .who{font-size:10px; color:var(--muted); display:flex; align-items:center; gap:6px; margin-bottom:3px;}
  .norm-item .who .dot{width:8px; height:8px;}
  .norm-num{font-size:26px; font-weight:700; line-height:1; letter-spacing:-.01em; font-variant-numeric:tabular-nums;}
  .norm-item.dfa .norm-num{color:var(--graphite);} .norm-item.sad .norm-num{color:var(--violet-deep);}
  .norm-unit{font-size:10px; color:var(--muted); margin-top:3px;}

  /* ---------- DEMOGRAPHICS ---------- */
  .demo-grid{display:flex; flex-direction:column; gap:13px;}
  .dm{display:grid; grid-template-columns:170px 1fr; gap:14px; align-items:center; break-inside:avoid;}
  .dm-title{font-size:12px; font-weight:600; color:var(--ink);}
  .dm-bars{display:flex; flex-direction:column; gap:5px;}
  .dm-row{display:flex; align-items:center; gap:9px;}
  .dm-track{flex:1; height:11px; background:var(--line2); border-radius:4px; overflow:hidden;}
  .dm-fill{height:100%; border-radius:4px;}
  .dm-fill.dfa{background:var(--graphite);}
  .dm-fill.sad{background:var(--violet);}
  .dm-val{font-size:10.5px; font-weight:700; font-variant-numeric:tabular-nums; width:30px; text-align:right; color:var(--ink2);}
  .demo-axis{margin-left:184px; margin-top:6px; font-size:9px; color:var(--faint); display:flex; justify-content:space-between;}

  /* ---------- FOOTNOTE / FOOTER ---------- */
  .footnote{
    margin-top:14px; padding:11px 14px; background:var(--wash);
    border:1px solid var(--line); border-left:3px solid var(--violet);
    border-radius:8px; font-size:10px; color:var(--ink2); line-height:1.55;
  }
  .footnote b{color:var(--ink); font-weight:600;}
  .doc-footer{
    margin-top:26px; padding-top:14px; border-top:1px solid var(--line);
    display:flex; justify-content:space-between; align-items:center;
    font-size:9.5px; color:var(--muted); letter-spacing:.02em;
  }
  .doc-footer .brand{font-weight:700; color:var(--ink2); letter-spacing:.04em;}

  @media print{
    body{background:#fff;}
    .sheet{max-width:none; margin:0; padding:0; box-shadow:none; border-radius:0;}
    .sheet::before{height:4px;}
    section{margin-top:24px;}
  }
</style>
</head>
<body>
  <div class="sheet">

    <!-- MASTHEAD -->
    <div class="masthead">
      <img class="logo" src="data:image/webp;base64," alt="Startup.Africa">
      <div class="meta">
        <span class="pill">Internal</span><br>
        Prepared for · <b>Bossa</b><br>
        Generated · <b>1 June 2026</b><br>
        Source · LinkedIn Newsletter Analytics
      </div>
    </div>

    <div class="title-block">
      <div class="eyebrow">LinkedIn Newsletter Performance</div>
      <h1 class="report-title">Comparative Review</h1>
      <div class="subtitle"><a class="vs" href="https://www.linkedin.com/newsletters/deal-flow-africa-7358414362824396800/?ref=startup.africa">Deal Flow Africa</a> &nbsp;vs&nbsp; <a class="vs" href="https://www.linkedin.com/newsletters/startup-africa-digest-7351626858028818432/?ref=startup.africa">Startup Africa Digest</a></div>
    </div>

    <!-- 1. NEWSLETTERS AT A GLANCE -->

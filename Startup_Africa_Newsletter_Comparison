        </div>
      </div>
    </section>

    <!-- 2. METRIC COMPARISON TABLE -->
    <section>
      <div class="sec-head"><span class="sec-num">2</span><h2>Metric comparison</h2></div>
      <table>
        <thead>
          <tr>
            <th>Metric</th>
            <th class="col-n"><span class="ch"><span class="chip dfa"></span>Deal Flow Africa</span></th>

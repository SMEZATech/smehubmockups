        <td class="t-num sad-col">12 months</td>
      </tr>
        </tbody>
      </table>
    </section>

    <!-- 3. VISUAL COMPARISON -->
    <section>
      <div class="sec-head"><span class="sec-num">3</span><h2>Visual comparison</h2></div>
      <div class="legend">
        <span class="lg"><span class="chip dfa"></span>Deal Flow Africa (DFA)</span>
        <span class="lg"><span class="chip sad"></span>Startup Africa Digest (SAD)</span>
